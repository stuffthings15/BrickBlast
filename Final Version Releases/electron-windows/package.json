{
  "name": "brickblast-velocity-market",
  "version": "1.0.0",
  "description": "BrickBlast: Velocity Market — Windows Electron wrapper",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --arm64"
  },
  "build": {
    "appId": "com.teamfasttalk.brickblast",
    "productName": "BrickBlast: Velocity Market",
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64", "arm64"] }],
      "icon": "game/favicon.ico"
    },
    "nsis": { "oneClick": false, "perMachine": false, "allowToChangeInstallationDirectory": true }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
